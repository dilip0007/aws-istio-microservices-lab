pipeline {
    options {
        buildDiscarder(logRotator(numToKeepStr: '1'))
    }
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: kaniko
                image: gcr.io/kaniko-project/executor:debug
                command:
                - sleep
                args:
                - 9999999
                volumeMounts:
                - name: docker-config
                  mountPath: /kaniko/.docker/
              - name: kubectl
                image: bitnami/kubectl:latest
                securityContext:
                  runAsUser: 0
                command:
                - sleep
                args:
                - 9999999
              volumes:
              - name: docker-config
                secret:
                  secretName: docker-credentials
                  items:
                    - key: config.json
                      path: config.json
            '''
        }
    }
    stages {
        stage('Build Image') {
            steps {
                container('kaniko') {
                    sh "/kaniko/executor --build-arg BUILDPLATFORM=linux/arm64 --build-arg TARGETARCH=arm64 --context ${WORKSPACE}/src/emailservice --dockerfile ${WORKSPACE}/src/emailservice/Dockerfile --destination dilipnigam007/emailservice:v${env.BUILD_NUMBER}"
                }
            }
        }
        stage('Deploy') {
            steps {
                container('kubectl') {
                    sh "kubectl set image deployment/emailservice server=docker.io/dilipnigam007/emailservice:v${env.BUILD_NUMBER} -n default"
                }
            }
        }
    }
}
